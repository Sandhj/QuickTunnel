[Unit]
Description=SSH Over Websocket Python By TheKill
Documentation=https://thekillstore.me
After=network.target nss-lookup.target

[Service]
Type=simple
User=root
Group=root

# Izin capability untuk binding port rendah (<1024) jika digunakan
CapabilityBoundingSet=CAP_NET_ADMIN CAP_NET_BIND_SERVICE
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_BIND_SERVICE
NoNewPrivileges=true

# Gunakan python3 untuk kompatibilitas Debian 12
ExecStart=/usr/bin/python3 -O /usr/local/bin/ws-stunnel 2097

# Restart policy
Restart=on-failure
RestartSec=5s

# Batasan sumber daya opsional
LimitNOFILE=65535
LimitMEMLOCK=infinity

[Install]
WantedBy=multi-user.target
